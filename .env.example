# Variables de entorno para Tuya/SmartLife
# Copia este archivo como .env y completa con tus datos

TUYA_ACCESS_ID=tu_access_id_aqui
TUYA_ACCESS_SECRET=tu_access_secret_aqui
TUYA_DEVICE_ID=device_id_del_termometro
TUYA_LOCAL_KEY=local_key_del_dispositivo
TUYA_DEVICE_IP=192.168.1.xxx

# HomePod (opcional - se empareja por linea de comandos la primera vez)
HOMEPOD_PIN=123-45-678
HOMEPOD_IP=192.168.1.xxx